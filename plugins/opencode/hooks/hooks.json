{
  "description": "Warm the OpenCode server at session start so the first dispatch is instant.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/warm-server-hook.mjs\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
